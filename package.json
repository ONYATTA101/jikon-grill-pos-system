{
  "name": "jikon-grill-pos",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "postinstall": "prisma generate",
    "vercel-build": "prisma migrate deploy && prisma db seed && next build",
    "start": "next start",
    "pos:start": "powershell -ExecutionPolicy Bypass -File scripts/start-pos.ps1",
    "pos:start:prod": "powershell -ExecutionPolicy Bypass -File scripts/start-pos.ps1 -Production",
    "pos:stop": "powershell -ExecutionPolicy Bypass -File scripts/stop-pos.ps1",
    "lint": "eslint .",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "db:backup": "powershell -ExecutionPolicy Bypass -File scripts/backup-db.ps1",
    "db:restore": "powershell -ExecutionPolicy Bypass -File scripts/restore-db.ps1",
    "release:check": "powershell -ExecutionPolicy Bypass -File scripts/release-check.ps1",
    "security:rotate-passwords": "tsx scripts/prepare-launch-credentials.ts ROTATE",
    "security:remove-reviewer": "tsx scripts/remove-interview-reviewer.ts REMOVE",
    "data:prepare-launch": "tsx scripts/prepare-launch-data.ts",
    "data:verify-launch": "tsx scripts/verify-launch-data.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "lucide-react": "^0.468.0",
    "next": "^16.2.6",
    "prisma": "^5.22.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "postcss": "8.5.15",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "overrides": {
    "postcss": "8.5.15"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
